{
  "name": "vue-showcase-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite --port 5173",
    "dev:portfolio": "cd apps/portfolio-app && npm run dev -- --port 5174",
    "dev:lms": "cd apps/lms-platform && npm run dev -- --port 3001",
    "dev:lms:backend": "cd apps/lms-platform && npx convex dev",
    "dev:airbnb": "cd apps/airbnb-clone && npm run dev -- --port 3002",
    "dev:airbnb:backend": "cd apps/airbnb-clone && npx convex dev",
    "dev:ecommerce": "cd apps/ecommerce-app && npm run dev -- --port 3003",
    "dev:all": "npx concurrently --kill-others --delay 3000 \"npm run dev:lms:backend\" \"npm run dev:airbnb:backend\" \"npm run dev:lms\" \"npm run dev:airbnb\" \"npm run dev:ecommerce\" \"npm run dev\"",
    "clean": "pkill -f \"nuxt|vite|node\" || true && rm -rf apps/**/.nuxt apps/**/.output",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7",
    "wait-on": "^9.0.5"
  }
}