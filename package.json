{
  "name": "vue-showcase-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite --port 5173",
    "dev:portfolio": "npm run dev --workspace=apps/portfolio-app -- --port 5174",
    "dev:lms": "npm run dev --workspace=apps/lms-platform -- --port 3001",
    "dev:lms:backend": "npm run --workspace=apps/lms-platform exec -- convex dev",
    "dev:airbnb": "npm run dev --workspace=apps/airbnb-clone -- --port 3002",
    "dev:ecommerce": "npm run dev --workspace=apps/ecommerce-app -- --port 3003",
    "dev:all": "npx concurrently \"npm run dev\" \"npm run dev:portfolio\" \"npm run dev:lms\" \"npm run dev:lms:backend\" \"npm run dev:airbnb\" \"npm run dev:ecommerce\"",

    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}

